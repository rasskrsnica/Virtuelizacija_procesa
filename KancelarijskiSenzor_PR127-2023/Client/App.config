<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <add key="DatasetPath" value="Data\Data.csv" />
    <add key="ClientRejectLogPath" value="Logs\client_rejects.csv" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <system.serviceModel>
    <bindings>
      <netTcpBinding>
        <binding name="SensorNetTcpBinding"
                 transferMode="Streamed"
                 maxReceivedMessageSize="10485760"
                 openTimeout="00:01:00"
                 closeTimeout="00:01:00"
                 sendTimeout="00:05:00"
                 receiveTimeout="00:10:00">
          <readerQuotas maxDepth="64"
                        maxStringContentLength="10485760"
                        maxArrayLength="10485760"
                        maxBytesPerRead="4096"
                        maxNameTableCharCount="16384" />
          <security mode="None" />
        </binding>
      </netTcpBinding>
    </bindings>
    <client>
      <endpoint name="SensorServiceEndpoint"
                address="net.tcp://localhost:9000/SensorService"
                binding="netTcpBinding"
                bindingConfiguration="SensorNetTcpBinding"
                contract="SensorCommon.Contracts.ISensorService" />
    </client>
  </system.serviceModel>
</configuration>
