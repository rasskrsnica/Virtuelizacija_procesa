<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <add key="StorageDirectory" value="..\..\..\Data\ServerStorage" />
    <add key="V_threshold" value="10" />
    <add key="T_bmp_threshold" value="1" />
    <add key="T_dht_threshold" value="1" />
    <add key="MeanDeviationPercent" value="25" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <system.serviceModel>
    <bindings>
      <netTcpBinding>
        <binding name="SensorNetTcpBinding"
                 transferMode="Streamed"
                 maxReceivedMessageSize="10485760"
                 openTimeout="00:01:00"
                 closeTimeout="00:01:00"
                 sendTimeout="00:05:00"
                 receiveTimeout="00:10:00">
          <readerQuotas maxDepth="64"
                        maxStringContentLength="10485760"
                        maxArrayLength="10485760"
                        maxBytesPerRead="4096"
                        maxNameTableCharCount="16384" />
          <security mode="None" />
        </binding>
      </netTcpBinding>
    </bindings>
    <services>
      <service name="SensorService.Service1">
        <host>
          <baseAddresses>
            <add baseAddress="net.tcp://localhost:9000/SensorService" />
          </baseAddresses>
        </host>
        <endpoint address=""
                  binding="netTcpBinding"
                  bindingConfiguration="SensorNetTcpBinding"
                  contract="SensorCommon.Contracts.ISensorService" />
        <endpoint address="mex" binding="mexTcpBinding" contract="IMetadataExchange" />
      </service>
    </services>
    <behaviors>
      <serviceBehaviors>
        <behavior>
          <serviceMetadata />
          <serviceDebug includeExceptionDetailInFaults="true" />
        </behavior>
      </serviceBehaviors>
    </behaviors>
  </system.serviceModel>
</configuration>
